{
  "name": "reli3",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Atlas cronológico y vectorial de religiones y tradiciones espirituales.",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "data": "node scripts/generate-data.mjs",
    "database": "node scripts/build-database.mjs",
    "predev": "npm run data && npm run database",
    "dev": "vite --host 0.0.0.0",
    "prebuild": "npm run data && npm run database",
    "build": "vite build",
    "preview": "vite preview --host 0.0.0.0",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "test": "vitest run",
    "validate": "npm run check && npm run test && npm run build"
  },
  "dependencies": {
    "@lucide/svelte": "^1.24.0",
    "@sveltejs/vite-plugin-svelte": "^7.2.0",
    "sql.js": "^1.14.1",
    "svelte": "^5.56.6",
    "vite": "^8.1.5"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/sql.js": "^1.4.11",
    "svelte-check": "^4.7.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10"
  }
}
